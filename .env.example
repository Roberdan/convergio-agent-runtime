# ============================================
# convergio-agent-runtime — Environment Variables
# ============================================

# --- Authentication (required) ---
# Auth token for Convergio API calls
CONVERGIO_AUTH_TOKEN=your-auth-token-here

# --- Infrastructure ---
# URL of the Convergio daemon (default: http://127.0.0.1:7777)
# CONVERGIO_DAEMON_URL=http://127.0.0.1:7777

# Root directory of the repository being managed
# CONVERGIO_REPO_ROOT=/path/to/your/repo

# Agent instance name identifier
# CONVERGIO_AGENT_NAME=my-agent

# --- External Binaries ---
# Path to Claude CLI binary (falls back to `which claude`)
# CONVERGIO_CLAUDE_BIN=/usr/local/bin/claude

# Path to GitHub CLI binary (falls back to `which gh`)
# CONVERGIO_GH_BIN=/usr/local/bin/gh

# --- Notifications (Telegram) ---
# Telegram bot token for sending notifications
# CONVERGIO_TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Telegram chat ID for receiving notifications
# CONVERGIO_TELEGRAM_CHAT_ID=your-chat-id-here

# --- AI Model ---
# Model name for Thor inference backend
# CONVERGIO_THOR_MODEL=claude-sonnet-4-20250514
